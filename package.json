{
  "name": "wishlist",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "sandbox": "AWS_DEFAULT_REGION=us-west-2 ampx sandbox --profile wishlist-website-claude",
    "sandbox:delete": "AWS_DEFAULT_REGION=us-west-2 ampx sandbox delete --profile wishlist-website-claude",
    "generate-outputs": "AWS_DEFAULT_REGION=us-west-2 ampx generate outputs --profile wishlist-website-claude"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.1.0",
    "aws-amplify": "^6.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.2.0",
    "@aws-amplify/backend-cli": "^1.2.0",
    "@aws-sdk/client-dynamodb": "^3.1030.0",
    "@aws-sdk/lib-dynamodb": "^3.1030.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
